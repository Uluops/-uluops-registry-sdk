{
  "name": "@uluops/registry-sdk",
  "version": "0.1.1",
  "description": "SDK for the UluOps Registry API - manage AI workflow definitions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "uluops",
    "registry",
    "definitions",
    "agents",
    "workflows",
    "sdk",
    "api"
  ],
  "author": "UluOps <hello@uluops.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Uluops/-uluops-registry-sdk.git"
  },
  "license": "MIT",
  "dependencies": {
    "@uluops/sdk-core": "^0.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.12.0",
    "eslint": "^9.39.2",
    "nock": "^14.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.0.4"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
