{
  "name": "@uluops/registry-sdk",
  "version": "0.30.1",
  "description": "SDK for the UluOps Registry API - manage AI workflow definitions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./config/constants": {
      "import": "./dist/config/constants.js",
      "types": "./dist/config/constants.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prebuild": "node --input-type=commonjs -e \"const v=JSON.parse(require('fs').readFileSync('package.json','utf8')).version;require('fs').writeFileSync('src/config/generated-version.ts','// Auto-generated by prebuild \\u2014 do not edit\\nexport const SDK_VERSION = \\x27'+v+'\\x27;\\n')\"",
    "build": "npm run prebuild && rimraf dist && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "prepublishOnly": "npm run lint && npm test && npm audit --audit-level=high --omit=dev && npm run build"
  },
  "keywords": [
    "uluops",
    "registry",
    "definitions",
    "agents",
    "workflows",
    "sdk",
    "api"
  ],
  "author": "UluOps <hello@uluops.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/uluops/-uluops-registry-sdk.git"
  },
  "license": "MIT",
  "dependencies": {
    "@uluops/sdk-core": "0.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.12.0",
    "eslint": "^9.39.2",
    "nock": "^14.0.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
